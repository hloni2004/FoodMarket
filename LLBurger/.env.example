# Copy this file to .env and fill in your actual values
# Supabase > Settings > Database > Connection Pooling > Session mode (port 5432)
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=your-database-password

# Supabase > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Brevo (Sendinblue) > SMTP & API > SMTP Keys
BREVO_SMTP_USERNAME=your-brevo-smtp-username
BREVO_SMTP_PASSWORD=your-brevo-smtp-password

# Mailjet > Account > API Keys
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_API_SECRET=your-mailjet-api-secret
